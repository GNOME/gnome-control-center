msgstr "ການເບິ່ງເຫັນ"

#: panels/universal-access/cc-ua-seeing-page.blp:18
msgid "Screen Reader"
msgstr "ຕົວອ່ານໜ້າຈໍ"

#: panels/universal-access/cc-ua-seeing-page.blp:26
msgid "Screen _Reader"
msgstr "ຕົວອ່ານໜ້າຈໍ (_R)"

