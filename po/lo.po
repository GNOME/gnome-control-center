msgid "Summary"
msgstr "ສະ​ຫຼຸບ"

#: panels/color/cc-color-panel.ui:259
msgid "Profile successfully created!"
msgstr "ສ້າງ​ໂປ​ຣ​ໄຟລ໌​ສຳ​ເລັດ​ແລ້ວ!"

#: panels/color/cc-color-panel.ui:290
msgid "Copy Profile"
msgstr "ສຳ​ເນົາ​ໂປ​ຣ​ໄຟລ໌"

