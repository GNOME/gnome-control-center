msgctxt "Password hint"
msgid "Try to use more uppercase letters"
msgstr "ພະຍາຍາມໃຊ້ຕົວອັກສອນພິມໃຫຍ່ໃຫ້ຫຼາຍຂຶ້ນ"

#: panels/system/users/pw-utils.c:127
msgctxt "Password hint"
msgid "Try to use more lowercase letters"
msgstr "ພະຍາຍາມໃຊ້ຕົວອັກສອນພິມນ້ອຍໃຫ້ຫຼາຍຂຶ້ນ"

#: panels/system/users/pw-utils.c:129
msgctxt "Password hint"
msgid "Try to use more special characters, like punctuation"
msgstr "ພະຍາຍາມໃຊ້ອັກຂະຫຼະພິເສດຕື່ມ, ເຊັ່ນ ເຄື່ອງໝາຍວັກຕອນ"

#: panels/system/users/pw-utils.c:131
msgctxt "Password hint"
msgid "Try to use a mixture of letters, numbers and punctuation"
msgstr "ພະຍາຍາມໃຊ້ຕົວອັກສອນ, ຕົວເລກ ແລະ ເຄື່ອງໝາຍວັກຕອນປະສົມກັນ"

#: panels/system/users/pw-utils.c:133
msgctxt "Password hint"
msgid "Try to avoid repeating the same character"
msgstr "ພະຍາຍາມຫຼີກລ້ຽງການໃຊ້ອັກຂະຫຼະດຽວກັນຊ້ຳໆ"

#: panels/system/users/pw-utils.c:135
msgctxt "Password hint"
msgid ""
"Try to avoid repeating the same type of character: you need to mix up "
"letters, numbers and punctuation"
msgstr "ພະຍາຍາມຫຼີກລ້ຽງການໃຊ້ອັກຂະຫຼະປະເພດດຽວກັນຊ້ຳໆ: ທ່ານຕ້ອງປະສົມຕົວອັກສອນ, ຕົວເລກ ແລະ ເຄື່ອງໝາຍວັກຕອນ"

#: panels/system/users/pw-utils.c:137
msgctxt "Password hint"
msgid "Try to avoid sequences like 1234 or abcd"
msgstr "ພະຍາຍາມຫຼີກລ້ຽງລຳດັບ ເຊັ່ນ 1234 ຫຼື abcd"

#: panels/system/users/pw-utils.c:139
msgctxt "Password hint"
msgid "Password needs to be longer"
msgstr "ລະຫັດຜ່ານຕ້ອງຍາວກວ່ານີ້"

#: panels/system/users/pw-utils.c:141
msgctxt "Password hint"
msgid "Mix uppercase and lowercase and try to use a number or two"
msgstr "ປະສົມຕົວພິມໃຫຍ່ ແລະ ຕົວພິມນ້ອຍ ແລະ ລອງໃຊ້ຕົວເລກໜຶ່ງ ຫຼື ສອງຕົວ"

#: panels/system/users/pw-utils.c:143
msgctxt "Password hint"
msgid "Valid password. Try adding more letters, numbers and punctuation"
msgstr "ລະຫັດຜ່ານໃຊ້ໄດ້. ລອງເພີ່ມຕົວອັກສອນ, ຕົວເລກ ແລະ ເຄື່ອງໝາຍວັກຕອນຕື່ມອີກ"

#: panels/system/users/pw-utils.c:183
msgid "Great password!"
msgstr "ລະຫັດຜ່ານດີເລີດ!"

#: panels/system/users/run-passwd.c:390
msgid "Authentication failed"
msgstr "ການຢືນຢັນຕົວຕົນລົ້ມເຫຼວ"

#: panels/system/users/run-passwd.c:469
#, c-format
msgid "The new password is too short"
msgstr "ລະຫັດຜ່ານໃໝ່ສັ້ນເກີນໄປ"

#: panels/system/users/run-passwd.c:475
#, c-format
msgid "The new password is too simple"
msgstr "ລະຫັດຜ່ານໃໝ່ງ່າຍເກີນໄປ"

#: panels/system/users/run-passwd.c:481
#, c-format
msgid "The old and new passwords are too similar"
msgstr "ລະຫັດຜ່ານເກົ່າ ແລະ ລະຫັດຜ່ານໃໝ່ຄືກັນເກີນໄປ"

#: panels/system/users/run-passwd.c:484
#, c-format
msgid "The new password has already been used recently."
msgstr "ລະຫັດຜ່ານໃໝ່ນີ້ຖືກໃຊ້ໄປແລ້ວເມື່ອບໍ່ດົນມານີ້."

#: panels/system/users/run-passwd.c:487
#, c-format
msgid "The new password must contain numeric or special characters"
msgstr "ລະຫັດຜ່ານໃໝ່ຕ້ອງມີຕົວເລກ ຫຼື ອັກຂະຫຼະພິເສດ"

#: panels/system/users/run-passwd.c:491
#, c-format
msgid "The old and new passwords are the same"
msgstr "ລະຫັດຜ່ານເກົ່າ ແລະ ລະຫັດຜ່ານໃໝ່ຄືກັນ"

#: panels/system/users/run-passwd.c:495
#, c-format
msgid "Your password has been changed since you initially authenticated!"
msgstr "ລະຫັດຜ່ານຂອງທ່ານໄດ້ຖືກປ່ຽນແປງແລ້ວນັບຕັ້ງແຕ່ທ່ານຢືນຢັນຕົວຕົນຄັ້ງທຳອິດ!"

#: panels/system/users/run-passwd.c:499
#, c-format
msgid "The new password does not contain enough different characters"
msgstr "ລະຫັດຜ່ານໃໝ່ມີອັກຂະຫຼະທີ່ແຕກຕ່າງກັນບໍ່ພຽງພໍ"

#: panels/system/users/run-passwd.c:503 panels/wwan/cc-wwan-errors-private.h:72
#, c-format
msgid "Unknown error"
msgstr "ຂໍ້ຜິດພາດທີ່ບໍ່ຮູ້ຈັກ"

#. Translators: '%s' is an invalid character, such as @, #, etc...
#: panels/system/users/user-utils.c:148
#, c-format
msgid "Usernames cannot include “%s”"
msgstr "ຊື່ຜູ້ໃຊ້ບໍ່ສາມາດມີ “%s” ໄດ້"

#: panels/system/users/user-utils.c:152
msgid "Username is already in use — please choose another"
msgstr "ຊື່ຜູ້ໃຊ້ນີ້ມີຄົນໃຊ້ແລ້ວ — ກະລຸນາເລືອກຊື່ອື່ນ"

#: panels/system/users/user-utils.c:195
#, c-format
msgid "Usernames must have fewer than %ld character"
msgstr "ຊື່ຜູ້ໃຊ້ຕ້ອງມີນ້ອຍກວ່າ %ld ອັກຂະຫຼະ"

#: panels/universal-access/cc-cursor-size-page.blp:5
msgid "Cursor Size"
msgstr "ຂະໜາດເຄີເຊີ"

#: panels/universal-access/cc-cursor-size-page.blp:12
msgid ""
"Cursor size can be combined with Zoom to make it easier to see the cursor"
msgstr "ຂະໜາດເຄີເຊີສາມາດໃຊ້ຮ່ວມກັບການຊູມເພື່ອໃຫ້ເຫັນເຄີເຊີໄດ້ງ່າຍຂຶ້ນ"

